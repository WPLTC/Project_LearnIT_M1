{
  "info": {
    "name": "LearnIT API - Collection",
    "_postman_id": "learnit-collection",
    "description": "Collection pour tester l'API (auth, reservations, emplois du temps)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"adminpass\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var resp = pm.response.json();",
              "if(resp.token){",
              "  pm.environment.set('token', resp.token);",
              "  console.log('Token saved to environment');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"password\",\n  \"email\": \"new@example.com\",\n  \"nom\": \"Nom\",\n  \"prenom\": \"Prenom\",\n  \"role\": \"ETUDIANT\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
      }
    },
    {
      "name": "Get EmploisDuTemps",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/emplois-du-temps", "host": ["{{baseUrl}}"], "path": ["api","emplois-du-temps"] }
      }
    },
    {
      "name": "Planifier cours (exemple)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"moduleId\": 1,\n  \"enseignantId\": 1,\n  \"salleId\": 1,\n  \"dateDebut\": \"2026-03-03T09:00:00\",\n  \"dateFin\": \"2026-03-03T11:00:00\",\n  \"recurrence\": \"NONE\",\n  \"statut\": \"PLANNIFIE\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/emplois-du-temps/planifier", "host": ["{{baseUrl}}"], "path": ["api","emplois-du-temps","planifier"] }
      }
    },
    {
      "name": "Get Reservations",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api","reservations"] }
      }
    },
    {
      "name": "Get Disponibilites (salle)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/reservations/disponibilites?salleId=2", "host": ["{{baseUrl}}"], "path": ["api","reservations","disponibilites"], "query": [ { "key": "salleId", "value": "2" } ] }
      }
    },
    {
      "name": "Create Reservation (exemple)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"userId\": 3,\n  \"salleId\": 2,\n  \"dateDebut\": \"2026-03-05T10:00:00\",\n  \"dateFin\": \"2026-03-05T12:00:00\",\n  \"motif\": \"Réunion projet\",\n  \"statut\": \"EN_ATTENTE\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api","reservations"] }
      }
    },
    {
      "name": "Presence - Marquer",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"emploiDuTempsId\": 1,\n  \"userId\": 3,\n  \"present\": true\n}" },
        "url": { "raw": "{{baseUrl}}/api/presences/marquer", "host": ["{{baseUrl}}"], "path": ["api","presences","marquer"] }
      }
    },
    {
      "name": "Modules - Get All",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/modules", "host": ["{{baseUrl}}"], "path": ["api","modules"] } }
    },
    {
      "name": "Etudiants - Get All",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/etudiants", "host": ["{{baseUrl}}"], "path": ["api","etudiants"] } }
    },
    {
      "name": "Enseignants - Get All",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/enseignants", "host": ["{{baseUrl}}"], "path": ["api","enseignants"] } }
    },
    {
      "name": "Classes - Get All",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/classes", "host": ["{{baseUrl}}"], "path": ["api","classes"] } }
    },
    {
      "name": "Evaluations - Get All",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/evaluations", "host": ["{{baseUrl}}"], "path": ["api","evaluations"] } }
    }
    ,
    {
      "name": "Salles - Get All",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/salles", "host": ["{{baseUrl}}"], "path": ["api","salles"] }
      }
    },
    {
      "name": "Salles - Get By Id",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/salles/1", "host": ["{{baseUrl}}"], "path": ["api","salles","1"] }
      }
    },
    {
      "name": "Salles - Create",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Salle 101\",\n  \"capacite\": 30,\n  \"localisation\": \"Bâtiment A - 1er\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/salles", "host": ["{{baseUrl}}"], "path": ["api","salles"] }
      }
    },
    {
      "name": "Salles - Update",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Salle 101 - Modifiée\",\n  \"capacite\": 35\n}" },
        "url": { "raw": "{{baseUrl}}/api/salles/1", "host": ["{{baseUrl}}"], "path": ["api","salles","1"] }
      }
    },
    {
      "name": "Salles - Delete",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/salles/1", "host": ["{{baseUrl}}"], "path": ["api","salles","1"] }
      }
    },
    {
      "name": "Notes - Get All",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/notes", "host": ["{{baseUrl}}"], "path": ["api","notes"] }
      }
    },
    {
      "name": "Notes - Get By Id",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/notes/1", "host": ["{{baseUrl}}"], "path": ["api","notes","1"] }
      }
    },
    {
      "name": "Notes - Create",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"etudiantId\": 3,\n  \"evaluationId\": 1,\n  \"valeur\": 15.5,\n  \"commentaire\": \"Bon travail\",\n  \"saisieParId\": 2\n}" },
        "url": { "raw": "{{baseUrl}}/api/notes", "host": ["{{baseUrl}}"], "path": ["api","notes"] }
      }
    },
    {
      "name": "Notes - Update",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"valeur\": 16.0,\n  \"commentaire\": \"Correction: 16\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/notes/1", "host": ["{{baseUrl}}"], "path": ["api","notes","1"] }
      }
    },
    {
      "name": "Notes - Delete",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/notes/1", "host": ["{{baseUrl}}"], "path": ["api","notes","1"] }
      }
    }
  ]
}
